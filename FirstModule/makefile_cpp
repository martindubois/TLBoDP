CFLAGS = @../Args/Kernel.args

OUTPUT = FirstModule_K.a

CPP_SOURCES = Driver.cpp

# ===== Rules ===============================================================

.cpp.o:
	g++ -c $(CFLAGS) -fno-rtti -o $@ $(INCLUDES) $<

# ===== Macros ==============================================================

CPP_OBJECTS = $(CPP_SOURCES:.cpp=.o)

# ===== Targets =============================================================

$(OUTPUT) : $(CPP_OBJECTS)
	ar r $@ $^
	ranlib $@
