Source: "x64\Debug\TLBoDP_K.lib"                            ; DestDir: "{app}\Libraries\Debug_x64"
Source: "x64\Debug\TLBoDP_K.pdb"                            ; DestDir: "{app}\Libraries\Debug_x64"
Source: "x64\Release\TLBoDP_K.lib"                          ; DestDir: "{app}\Libraries\Release_x64"
