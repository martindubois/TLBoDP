CFLAGS = -D_TLBoDP_LINUX_ @../Args/Kernel.args

INCLUDES = -I../Includes

OUTPUT = PCIe_K.a

CPP_SOURCES = Device.cpp

# ===== Rules ===============================================================

.cpp.o:
	g++ -c $(CFLAGS) -fno-rtti -o $@ $(INCLUDES) $<

# ===== Macros ==============================================================

CPP_OBJECTS = $(CPP_SOURCES:.cpp=.o)

# ===== Targets =============================================================

$(OUTPUT) : $(CPP_OBJECTS)
	ar r $@ $^
	ranlib $@
